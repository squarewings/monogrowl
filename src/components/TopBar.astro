---
// Top nav strip with live-dot + center links + location.
interface Props {
  location?: string;
  year?: string;
}
const { location = "Sheffield ↔ Brooklyn", year = "Est. 2018" } = Astro.props;
---

<header class="k-top">
  <div class="l">
    <span class="dot" aria-hidden="true"></span>
    <span>Monogrowl / {year}</span>
  </div>
  <nav class="c" aria-label="Primary">
    <a href="#listen">Listen</a>
    <a href="#releases">Releases</a>
    <a href="#visualiser">Visualiser</a>
    <a href="#bio">Bio</a>
  </nav>
  <div class="r">
    <span class="blink" aria-hidden="true">•</span>
    <span>{location}</span>
  </div>
</header>

<style lang="scss">
  @use "../styles/global.scss" as *;

  .k-top {
    position: relative;
    z-index: 5;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 20px;
    align-items: center;
    padding: 18px 28px;
    border-bottom: 1px solid $line;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #a4a4a0;

    .l, .c, .r {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .c { justify-content: center; }
    .r { justify-content: flex-end; }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 12px var(--accent);
      animation: pulse 1.8s infinite;
    }
    .blink { animation: blink 1.1s steps(2, end) infinite; }

    a { transition: color .25s; }
    a:hover { color: $fg; }
  }

  @media (max-width: 900px) {
    .k-top {
      grid-template-columns: 1fr;
      text-align: center;
      .l, .c, .r { justify-content: center; }
    }
  }
</style>
