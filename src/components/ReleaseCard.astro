---
interface Props {
  title: string;
  cat: string;               // "MG/SG/2024 · Single · Self-released"
  image: string;             // path under /images/…
  listenUrl: string;
  tracks: { no: string; name: string; len: string }[];
}
const { title, cat, image, listenUrl, tracks } = Astro.props;
---

<article class="k-rel-card">
  <div
    class="cov"
    style={`background-image:url('${image}'); background-size:cover; background-position:center`}
    aria-label={`${title} cover`}
  ></div>
  <div class="body">
    <div class="cat">{cat}</div>
    <h3>{title}</h3>
    <div class="tracklist">
      {tracks.map((t) => (
        <div class="rw">
          <span>{t.no}</span>
          <span>{t.name}</span>
          <span>{t.len}</span>
        </div>
      ))}
    </div>
    <a class="listen" href={listenUrl} target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" width="10" height="10" fill="currentColor" aria-hidden="true">
        <path d="M8 5v14l11-7z" />
      </svg>
      Open on Spotify
    </a>
  </div>
</article>

<style lang="scss">
  @use "../styles/global.scss" as *;

  .k-rel-card {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 1.2fr;
    gap: 24px;
    padding: 22px;
    border: 1px solid $line;
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.018), transparent 60%);
    transition: transform .45s cubic-bezier(.2, .8, .2, 1), border-color .3s;

    &:hover {
      transform: translateY(-4px);
      border-color: color-mix(in oklab, var(--accent) 80%, transparent);
    }

    .cov {
      aspect-ratio: 1;
      border-radius: 12px;
      background-color: #141416;
    }

    .body {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 4px 0;
    }

    .cat {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }

    h3 {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 400;
      font-size: clamp(2rem, 3.3vw, 3rem);
      line-height: 0.92;
      letter-spacing: -0.015em;
      margin-top: 8px;
    }

    .tracklist {
      margin-top: 16px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.06em;
      color: #b2b2ac;

      .rw {
        display: grid;
        grid-template-columns: 24px 1fr auto;
        gap: 10px;
        padding: 6px 0;
        border-top: 1px solid $line;

        span:first-child { color: #666; }
        span:last-child { color: #888; }
      }
    }

    .listen {
      align-self: flex-start;
      margin-top: 18px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #e0e0dc;
      transition: all .3s;

      &:hover {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
      }
    }
  }

  @media (max-width: 900px) {
    .k-rel-card { grid-template-columns: 1fr; }
  }
</style>
