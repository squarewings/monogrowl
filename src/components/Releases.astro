---
import ReleaseCard from "./ReleaseCard.astro";

const releases = [
  {
    title: "Overflown",
    cat: "MG/SG/2024 · Single · Self-released",
    image: "/images/overflown.jpg",
    listenUrl: "https://open.spotify.com/album/2vgmjUCApm3U96bzqMrLVg",
    tracks: [
      { no: "01", name: "Overflown", len: "04:12" },
      { no: "02", name: "Overflown (Sub-only)", len: "04:12" },
    ],
  },
  {
    title: "Monogrowl",
    cat: "MG/SG/2018 · Single · Debut",
    image: "/images/monogrowl.jpg",
    listenUrl: "https://open.spotify.com/album/4I14AwWBSp4KhHPtqqOmKR",
    tracks: [{ no: "01", name: "Monogrowl", len: "03:58" }],
  },
];
---

<section class="k-rel" id="releases">
  <div class="k-hd">
    <span>§ Releases <span class="ac">(03)</span></span>
    <span>02 · 2018 → 2024</span>
  </div>
  <div class="k-rel-grid">
    {releases.map((r) => <ReleaseCard {...r} />)}
  </div>
</section>

<style lang="scss">
  @use "../styles/global.scss" as *;

  .k-rel {
    position: relative;
    z-index: 2;
    max-width: 1480px;
    margin: 0 auto;
    padding: 40px 28px 80px;
  }

  .k-hd {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 20px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #888;
    border-bottom: 1px solid $line;
    padding-bottom: 12px;

    .ac { color: var(--accent); }
  }

  .k-rel-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) {
    .k-rel-grid { grid-template-columns: 1fr; }
  }
</style>
