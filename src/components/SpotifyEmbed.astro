---
interface Props {
  artistId: string;
}

const { artistId } = Astro.props;
const embedUrl = `https://open.spotify.com/embed/artist/${artistId}?utm_source=generator&theme=0`;
---

<section class="embed-section">
  <h2 class="section-label embed-label">Featured</h2>
  <div class="spotify-embed">
    <iframe
      src={embedUrl}
      width="100%"
      height="352"
      title="Monogrowl on Spotify"
      allowfullscreen
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      loading="lazy"
      style="display:block; border:none;"
    ></iframe>
  </div>
</section>

<style lang="scss">
  @use '../styles/global.scss' as *;

  .embed-section {
    padding: 1rem 2.5rem 4rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .embed-label {
    margin-bottom: 1rem;
  }

  .spotify-embed {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid $border;
  }
</style>
