---
interface Props {
  artistId: string;
}
const { artistId } = Astro.props;
// Monogrowl uses the artist embed; drop directly on the live site.
const src = `https://open.spotify.com/embed/artist/${artistId}?utm_source=generator&theme=0`;
---

<section class="k-now">
  <div class="slab">
    <div class="l">
      <div>
        <div class="small">
          <span>● Now playing</span>
          <span>Spotify embed</span>
        </div>
        <h2>Let the <em>sub</em> do the talking.</h2>
      </div>
      <p>
        Live player for the full Monogrowl catalogue on Spotify — sits at the
        bottom of the page, one more chance to press play.
      </p>
      <div class="small">
        <span>Format</span><span>Spotify · Artist</span><span>Height 352</span>
      </div>
    </div>
    <div class="r">
      <!-- Click-to-load facade (SPEC N1): the Spotify iframe (~1MB of
           third-party payload) is only injected on interaction. -->
      <button class="facade" type="button" data-embed-src={src}>
        <span class="play" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
        Load the Spotify player
      </button>
    </div>
  </div>
</section>

<script>
  const facade = document.querySelector<HTMLButtonElement>(".k-now .facade");
  facade?.addEventListener("click", () => {
    const iframe = document.createElement("iframe");
    iframe.src = facade.dataset.embedSrc!;
    iframe.width = "100%";
    iframe.height = "352";
    iframe.loading = "lazy";
    iframe.title = "Monogrowl on Spotify";
    iframe.allow =
      "autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture";
    facade.replaceWith(iframe);
    iframe.focus();
  });
</script>

<style lang="scss">
  @use "../styles/tokens" as *;

  .k-now {
    position: relative;
    z-index: 2;
    max-width: 1480px;
    margin: 0 auto;
    padding: 20px 28px 120px;
  }

  .slab {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 0;
    border: 1px solid $line;
    border-radius: 18px;
    overflow: hidden;
    background: #070709;
  }

  .l {
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
    border-right: 1px solid $line;

    h2 {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: clamp(2rem, 3.4vw, 2.8rem);
      line-height: 1;
      letter-spacing: -0.01em;
      margin-top: 14px;

      :global(em) { color: var(--accent); }
    }

    p {
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.55;
      color: #b1b1ac;
      max-width: 460px;
    }

    .small {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: $dim-2;
      display: flex;
      gap: 14px;

      span:first-child { color: var(--accent); }
    }
  }

  .r {
    position: relative;
    min-height: 352px;
    background: #0a0a0c;
    display: flex;
    align-items: center;
    justify-content: center;

    iframe {
      width: 100%;
      height: 100%;
      min-height: 352px;
      border: 0;
      background: transparent;
    }

    .facade {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      padding: 16px 24px;
      border: 1px solid var(--accent);
      border-radius: 999px;
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      transition: background .3s, color .3s, box-shadow .3s;

      .play {
        display: inline-flex;
        align-items: center;
      }

      &:hover {
        background: var(--accent);
        color: #000;
        box-shadow: 0 0 40px color-mix(in oklab, var(--accent) 40%, transparent);
      }
    }
  }

  @media (max-width: 900px) {
    .slab { grid-template-columns: 1fr; }
    .l { border-right: 0; border-bottom: 1px solid $line; }
  }
</style>
