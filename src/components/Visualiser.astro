---
// Preview block for visualiser.monogrowl.com, with a small inline canvas
// animation (no GL, just 2D canvas — GPU visualiser lives on its own domain).
interface Props {
  href?: string;
}
const { href = "https://visualiser.monogrowl.com" } = Astro.props;
---

<section class="k-viz" id="visualiser">
  <div class="card">
    <div class="viz-canvas">
      <div class="kicker">
        <span><span class="ac">●</span> LIVE · WEBGL</span>
        <span>visualiser.monogrowl.com</span>
      </div>
      <canvas id="kviz"></canvas>
    </div>
    <div class="body">
      <div>
        <div class="tag">§ Featured · <span class="ac">Visualiser</span></div>
        <h3>Seven modes. One <em>sub</em>.</h3>
      </div>
      <p>
        The Monogrowl visualiser — wireframe cities, particle swarms, reactive
        spheres — runs in the browser and responds to the music in real time.
        Open it in a second tab, turn it up, keep scrolling.
      </p>
      <div class="row">
        <div>Modes<span class="v">07</span></div>
        <div>Runtime<span class="v">Cloudflare Workers</span></div>
        <div>Rendering<span class="v">WebGL · GPU</span></div>
        <div>Best with<span class="v">Headphones</span></div>
      </div>
      <a class="go" href={href} target="_blank" rel="noopener">
        Open the visualiser
        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M7 17L17 7M9 7h8v8" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Small 2D-canvas preview — not GL, just a loop to evoke reactivity.
  const c = document.getElementById("kviz") as HTMLCanvasElement | null;
  if (c) {
    const ctx = c.getContext("2d")!;
    const resize = () => {
      const r = c.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      c.width = Math.max(10, r.width * dpr);
      c.height = Math.max(10, r.height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener("resize", resize);

    const accentRGB = (): [number, number, number] => {
      const hex = (getComputedStyle(document.documentElement)
        .getPropertyValue("--accent")
        .trim() || "#caff00").replace("#", "");
      const n = parseInt(hex, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };

    let t = 0;
    const frame = () => {
      if (document.body.dataset.motion === "off") {
        requestAnimationFrame(frame);
        return;
      }
      t += 0.014;
      const w = c.clientWidth,
        h = c.clientHeight;
      const [r, g, b] = accentRGB();
      ctx.fillStyle = "rgba(6,6,10,.3)";
      ctx.fillRect(0, 0, w, h);

      const bars = 40;
      for (let i = 0; i < bars; i++) {
        const bh = (Math.sin(t * 1.5 + i * 0.3) * 0.5 + 0.5) * h * 0.55 + 10;
        const bw = w / bars;
        const alpha = 0.5 + 0.4 * Math.sin(t + i * 0.2);
        ctx.fillStyle =
          i % 4 === 0
            ? `rgba(${r},${g},${b},${alpha})`
            : `rgba(255,255,255,${alpha * 0.3})`;
        ctx.fillRect(i * bw + 2, h - bh, bw - 4, bh);
      }
      for (let i = 0; i < 60; i++) {
        const x = (w * 0.5 + Math.cos(t * 0.6 + i) * w * 0.4 + i * 7) % w;
        const y = h * 0.5 + Math.sin(t * 0.5 + i * 0.7) * h * 0.35;
        ctx.fillStyle = `rgba(${r},${g},${b},${0.3 + 0.6 * Math.sin(t + i)})`;
        ctx.beginPath();
        ctx.arc(x, y, 1.5, 0, Math.PI * 2);
        ctx.fill();
      }
      requestAnimationFrame(frame);
    };
    requestAnimationFrame(frame);
  }
</script>

<style lang="scss">
  @use "../styles/global.scss" as *;

  .k-viz {
    position: relative;
    z-index: 2;
    max-width: 1480px;
    margin: 0 auto;
    padding: 0 28px 40px;
  }

  .card {
    position: relative;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 0;
    border: 1px solid $line;
    border-radius: 20px;
    overflow: hidden;
    background: #0b0b0d;
    min-height: 420px;
  }

  .viz-canvas {
    position: relative;
    background:
      radial-gradient(50% 50% at 30% 40%, color-mix(in oklab, var(--accent) 25%, transparent), transparent 70%),
      radial-gradient(60% 60% at 80% 80%, rgba(255, 255, 255, 0.06), transparent 70%),
      #07070a;
    overflow: hidden;

    canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }
  }

  .kicker {
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #aaa;
    z-index: 2;

    .ac { color: var(--accent); }
  }

  .body {
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 28px;
    border-left: 1px solid $line;

    .tag {
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 12px;

      .ac { color: var(--accent); }
    }

    h3 {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: clamp(2.4rem, 4.2vw, 3.6rem);
      line-height: 0.95;
      letter-spacing: -0.015em;
      color: $fg;

      :global(em) { color: var(--accent); }
    }

    p {
      font-family: var(--font-body);
      font-size: 1.05rem;
      line-height: 1.55;
      color: #b5b5af;
      max-width: 440px;
    }

    .row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #888;

      .v { color: $fg; display: block; margin-top: 4px; }
    }

    .go {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 16px 24px;
      border-radius: 999px;
      background: var(--accent);
      color: #000;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 600;
      width: fit-content;
      transition: transform .3s, box-shadow .3s;
      box-shadow: 0 10px 40px color-mix(in oklab, var(--accent) 30%, transparent);

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 50px color-mix(in oklab, var(--accent) 45%, transparent);
      }
    }
  }

  @media (max-width: 900px) {
    .card { grid-template-columns: 1fr; }
    .viz-canvas { min-height: 260px; }
    .body { border-left: 0; border-top: 1px solid $line; padding: 28px; }
  }
</style>
