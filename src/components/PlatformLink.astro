---
interface Props {
  href: string;
  label: string;
  disabled?: boolean;
}

const { href, label, disabled = false } = Astro.props;
---

<a
  class:list={['platform-btn', { bandcamp: disabled }]}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={disabled ? `${label} coming soon` : `${label} (opens in new tab)`}
>
  <slot />
  {label}
</a>

<style lang="scss">
  @use '../styles/global.scss' as *;

  .platform-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.1rem;
    background: #1a1a1a;
    border: 1px solid #2e2e2e;
    border-radius: 6px;
    color: #e8e8e8;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: inherit;
    transition: border-color 0.15s, background 0.15s, color 0.15s, transform 0.1s, box-shadow 0.15s;

    &:hover {
      border-color: $accent;
      background: #222;
      color: #fff;
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
    }

    &:active {
      transform: translateY(0);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
    }

    &:focus-visible {
      outline: 2px solid $accent;
      outline-offset: 2px;
      border-color: $accent;
      background: #222;
      color: #fff;
    }

    :global(.icon) {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      opacity: 0.85;
      transition: opacity 0.15s;
    }

    &:hover :global(.icon),
    &:focus-visible :global(.icon) {
      opacity: 1;
      color: $accent;
    }

    &.bandcamp {
      border-style: dashed;
      opacity: 0.5;
      pointer-events: none;

      &::after {
        content: 'soon';
        margin-left: auto;
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        color: $muted;
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .platform-btn {
      transition: border-color 0.15s, background 0.15s, color 0.15s, box-shadow 0.15s;

      &:hover {
        transform: none;
      }
    }
  }
</style>
