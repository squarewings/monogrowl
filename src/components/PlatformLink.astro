---
interface Props {
  href: string;
  label: string;
  disabled?: boolean;
}

const { href, label, disabled = false } = Astro.props;
---

<a
  class:list={['platform-btn', { bandcamp: disabled }]}
  href={href}
  target="_blank"
  rel="noopener"
  aria-label={disabled ? `${label} coming soon` : undefined}
>
  <slot />
  {label}
</a>

<style lang="scss">
  @use '../styles/global.scss' as *;

  .platform-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.1rem;
    background: #1a1a1a;
    border: 1px solid #2e2e2e;
    border-radius: 6px;
    color: #e8e8e8;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: inherit;
    transition: border-color 0.15s, background 0.15s, color 0.15s, transform 0.1s;

    &:hover {
      border-color: $accent;
      background: #222;
      color: #fff;
      transform: translateY(-1px);
    }

    :global(.icon) {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      opacity: 0.85;
    }

    &.bandcamp {
      border-style: dashed;
      opacity: 0.5;
      pointer-events: none;

      &::after {
        content: 'soon';
        margin-left: auto;
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        color: $muted;
      }
    }
  }
</style>
