---
interface Props {
  href: string;
  num: string;      // "01 / stream"
  label: string;    // "Spotify"
  sub: string;      // "monthly listeners · full catalogue"
}
const { href, num, label, sub } = Astro.props;
---

<a href={href} target="_blank" rel="noopener">
  <div class="num">{num}</div>
  <slot />
  <div>
    <div class="lbl">{label}</div>
    <div class="sub">{sub}</div>
  </div>
</a>

<style lang="scss">
  @use "../styles/global.scss" as *;

  a {
    position: relative;
    padding: 28px 22px 22px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 170px;
    border-right: 1px solid $line;
    transition: background .3s, color .3s;
    overflow: hidden;

    &:last-child { border-right: 0; }
    &:hover { background: var(--accent); color: #000; }
    &:hover .num,
    &:hover .sub { color: rgba(0, 0, 0, 0.7); }
  }

  .num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    color: #777;
  }

  .lbl {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 2.1rem;
    line-height: 0.95;
    letter-spacing: -0.01em;
  }

  .sub {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #777;
    margin-top: 6px;
  }

  :global(svg.ico) {
    position: absolute;
    top: 22px;
    right: 22px;
    width: 20px;
    height: 20px;
    color: #bababa;
    transition: color .3s;
  }
  a:hover :global(svg.ico) { color: #000; }
</style>
