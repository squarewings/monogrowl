---
import { Font } from 'astro:assets';
import { RELEASES } from '../data/releases';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Monogrowl | bass, beats, beers and brunch. Electronic music from Sheffield and Brooklyn.",
  ogImage = "/images/monogrowl.jpg",
  canonicalUrl = Astro.url.href,
} = Astro.props;

const siteName = "Monogrowl";
const siteUrl = "https://monogrowl.com";
const absoluteOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#060608" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Monogrowl, electronic music, synthesizers, Sheffield, Brooklyn, bass, beats"
    />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="2048" />
    <meta property="og:image:height" content="2048" />
    <meta property="og:image:alt" content="Monogrowl cover artwork" />
    <meta property="og:type" content="music.musician" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/monogrowl.jpg" />

    <!-- Analytics -->
    <link rel="preconnect" href="https://plausible.io" crossorigin />
    <link rel="dns-prefetch" href="https://plausible.io" />
    <script async src="https://plausible.io/js/pa-_D6-tnFYaotbVXJiOjaFm.js"></script>
    <script>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init();
    </script>

    <!-- Structured Data: MusicGroup + MusicAlbum graph (SPEC S2).
         Albums reference the artist by @id; data from src/data/releases.ts. -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "MusicGroup",
            "@id": `${siteUrl}/#artist`,
            name: "Monogrowl",
            url: siteUrl,
            description:
              "Bass, beats, beers and brunch. Electronic music from Sheffield and Brooklyn.",
            genre: ["Electronic", "Bass", "Synth"],
            foundingLocation: {
              "@type": "City",
              name: "Sheffield",
              addressCountry: "GB",
            },
            image: {
              "@type": "ImageObject",
              url: `${siteUrl}/images/monogrowl.jpg`,
              width: 2048,
              height: 2048,
            },
            member: { "@type": "Person", name: "Tyler Langan" },
            sameAs: [
              "https://open.spotify.com/artist/5ESygfI91sh8X4emLEeJ40",
              "https://music.apple.com/gb/album/overflown-single/1761736992",
              "https://soundcloud.com/monogrowl",
              "https://www.instagram.com/monogrowl/",
              "https://visualiser.monogrowl.com",
            ],
          },
          ...RELEASES.map((r) => ({
            "@type": "MusicAlbum",
            "@id": `${siteUrl}/#album-${r.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`,
            name: r.title,
            datePublished: String(r.year),
            byArtist: { "@id": `${siteUrl}/#artist` },
            albumReleaseType: "https://schema.org/SingleRelease",
            image: `${siteUrl}${r.image.src}`,
            url: r.listenUrl,
            numTracks: r.tracks.length,
            track: r.tracks.map((t, i) => ({
              "@type": "MusicRecording",
              position: i + 1,
              name: t.name,
              duration: t.iso,
            })),
          })),
        ],
      })}
    />

    <!-- Fonts (astro:assets handles preload + subset).
         Only the above-the-fold faces preload: serif (hero display) and
         mono (top bar / labels). Body face loads normally. -->
    <Font cssVariable="--font-body" />
    <Font cssVariable="--font-serif" preload />
    <Font cssVariable="--font-mono" preload />
  </head>
  <body>
    <script>
      import { syncMotionFlag } from "../scripts/motion";
      syncMotionFlag();
    </script>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>

<style lang="scss" is:global>
  @use "../styles/global.scss";
</style>
