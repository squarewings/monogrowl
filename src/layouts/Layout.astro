---
import { Font } from 'astro:assets';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Monogrowl | bass, beats, beers and brunch. Electronic music from Sheffield and Brooklyn.",
  ogImage = "/images/monogrowl.jpg",
  canonicalUrl = Astro.url.href,
} = Astro.props;

const siteName = "Monogrowl";
const siteUrl = "https://monogrowl.com";
const absoluteOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <!-- Scroll-reveal: set class synchronously to prevent FOIC; wire observer after DOM ready -->
    <script is:inline>
      document.documentElement.classList.add('js-ready');
      document.addEventListener('DOMContentLoaded', function () {
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('in-view');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );
        document
          .querySelectorAll('.bio-section, .links-section, .music-section, .embed-section')
          .forEach(function (el) { io.observe(el); });
      });
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Monogrowl, electronic music, synthesizers, Sheffield, Brooklyn, bass, beats"
    />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:type" content="music.musician" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_GB" />

    <!-- Open Graph image dimensions (improves social preview rendering) -->
    <meta property="og:image:width" content="2048" />
    <meta property="og:image:height" content="2048" />
    <meta property="og:image:alt" content="Monogrowl – Electronic music from Sheffield &amp; Brooklyn" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content="Monogrowl – Electronic music from Sheffield &amp; Brooklyn" />

    <!-- Theme colour for mobile browser chrome -->
    <meta name="theme-color" content="#080808" />

    <!-- Preload hero image for faster LCP -->
    <link rel="preload" as="image" href="/images/monogrowl.webp" type="image/webp" fetchpriority="high" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/monogrowl.jpg" />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://plausible.io" crossorigin />
    <link rel="dns-prefetch" href="https://plausible.io" />
    <link rel="preconnect" href="https://open.spotify.com" crossorigin />
    <link rel="dns-prefetch" href="https://open.spotify.com" />

    <!-- Analytics -->
    <script defer data-domain="monogrowl.com" src="https://plausible.io/js/script.js"></script>

    <!-- Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MusicGroup",
        name: "Monogrowl",
        url: siteUrl,
        description:
          "Bass, beats, beers and brunch. Electronic music from Sheffield and Brooklyn.",
        genre: ["Electronic", "Bass", "Synth"],
        foundingLocation: {
          "@type": "City",
          name: "Sheffield",
          addressCountry: "GB",
        },
        image: {
          "@type": "ImageObject",
          url: `${siteUrl}/images/monogrowl.jpg`,
          width: 2048,
          height: 2048,
        },
        member: {
          "@type": "Person",
          name: "Tyler Langan",
        },
        sameAs: [
          "https://open.spotify.com/artist/5ESygfI91sh8X4emLEeJ40",
          "https://music.apple.com/gb/album/overflown-single/1761736992",
          "https://soundcloud.com/monogrowl",
          "https://www.instagram.com/monogrowl/",
        ],
      })}
    />
    <!-- Fonts -->
    <Font cssVariable="--font-body" preload />
    <Font cssVariable="--font-display" preload />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>

<style lang="scss" is:global>
  @use "../styles/global.scss";
</style>
